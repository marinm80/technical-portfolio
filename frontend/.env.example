# Todas las variables son OPCIONALES: sin ellas el sitio funciona en modo degradado.
# Vite las inyecta en BUILD time (no en runtime): en Docker se pasan con --build-arg.

# --- Blog (WordPress REST API) ---
# URL base del WordPress (sin /wp-json). Sin esta variable, la página de
# artículos muestra un estado vacío "Próximamente".
VITE_WP_API_URL=https://blog.rafaelmarin.dev

# --- Formulario de contacto (EmailJS) ---
# Credenciales del dashboard de emailjs.com. La plantilla debe usar las
# variables {{name}}, {{email}} y {{message}}. Sin estas 3 claves, la página
# de contacto muestra un fallback mailto:.
# Nota: las claves VITE_* son públicas por diseño (van en el bundle del
# cliente); la protección real es el allowlist de dominios en EmailJS.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
