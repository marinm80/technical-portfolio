# Variables para docker compose (build args del frontend).
# Copia este archivo a .env en la raíz. Todas son opcionales:
# sin ellas el sitio funciona en modo degradado.

# Puerto del host que expone el contenedor (NPM proxya hacia él)
PORTFOLIO_PORT=8080

# Blog WordPress (sin /wp-json). Vacío = página de artículos en "Próximamente".
VITE_WP_API_URL=

# EmailJS (claves públicas por diseño; la protección real es el
# allowlist de dominios en el dashboard de emailjs.com)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
